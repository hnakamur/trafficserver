" flag has the same behavior as :option:`traffic_ctl config get "
"--records`."
msgstr ""

# 6e850117e644401aa2b2cd40f0b48460
#: ../../appendices/command-line/traffic_ctl.en.rst:109
msgid ""
"Display all the known information about a configuration record. This "
"includes the current and default values, the data type, the record class "
"and syntax checking expression."
msgstr ""

# 0ebfae453de64ea98b3c5b93fa1a22ce
#: ../../appendices/command-line/traffic_ctl.en.rst:116
msgid ""
