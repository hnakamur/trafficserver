# 465aa4f7cad04d28b0b4b70add39894c
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1027
msgid "Cache Result Codes"
msgstr ""

# 15b94033e301445e921234078f994f05
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1029
msgid ""
"The following table describes the cache result codes in Squid and "
"Netscape log files."
msgstr ""

# ca0e0ab06240492b818a81c265ef3887
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1034
msgid "``TCP_HIT``"
msgstr ""

# 8ef9ca402e3745a2b57b1d3151a2794d
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1033
msgid ""
"A valid copy of the requested object was in the cache and Traffic Server "
"sent the object to the client."
msgstr ""

# bef42ec49f0342f78694ab562d51cf53
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1039
msgid "``TCP_MISS``"
msgstr ""

# 5945e25806ef4b109b79dbe516077079
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1037
msgid ""
"The requested object was not in cache, so |TS| retrieved the object from "
"the origin server (or a parent proxy) and sent it to the client."
msgstr ""

# 8e2b4ff918554f32b063816500c8fc27
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1045
msgid "``TCP_REFRESH_HIT``"
msgstr ""

# b7a613b6658a44f29abf602fc09d8765
#: ../../admin-guide/monitoring/logging/log-formats.en.rst:1042
msgid ""
"The object was in the cache, but it was stale. |TS| made an ``if-"
"modified-since`` request to the origin server and the origin server sent "
