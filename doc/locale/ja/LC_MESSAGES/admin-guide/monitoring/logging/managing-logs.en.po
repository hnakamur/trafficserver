# cf7995ac9245435197bbb8f39f999626
#: ../../admin-guide/monitoring/logging/managing-logs.en.rst:308
msgid "ICP Log Splitting"
msgstr ""

# 13b8983a7e024fc19cf81c869c57d79f
#: ../../admin-guide/monitoring/logging/managing-logs.en.rst:310
msgid ""
"By default, |TS| uses standard log formats and generates log files that "
"contain HTTP and ICP transactions in the same file. However, you can "
"enable log splitting if you prefer to log transactions for different "
"protocols in separate log files."
msgstr ""

# 52e8dc21286745e88d008eb1ad839ac6
#: ../../admin-guide/monitoring/logging/managing-logs.en.rst:315
msgid ""
"When ICP log splitting is enabled, |TS| records ICP transactions in a "
"separate log file with a name that contains ``icp``. For example, if you "
"enable the Squid format, then all ICP transactions are recorded in the "
"``squid-icp.log`` file. When you disable ICP log splitting, |TS| records "
"all ICP transactions in the same log file as HTTP transactions."
msgstr ""

