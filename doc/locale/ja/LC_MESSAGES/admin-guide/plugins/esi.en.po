msgid "Enabling ESI"
msgstr ""

# c1b3c80d35cc4ea5803d389b26d644ef
#: ../../admin-guide/plugins/esi.en.rst:75
msgid ""
"First we need to set up /usr/local/etc/trafficserver/plugin.config and "
"make sure the following line is present."
msgstr ""

# a31ff67b0dea46f29c76351dd63c4b0a
#: ../../admin-guide/plugins/esi.en.rst:81
msgid "There are four options you can add to the above."
msgstr ""

# cdb7ce8d867d485d9a740c96366b6a07
#: ../../admin-guide/plugins/esi.en.rst:83
msgid ""
"\"--private-response\" will add private cache control and expires header "
"to the processed ESI document."
msgstr ""

# efa9a4752c0445a5adcf84837bd7c1fa
#: ../../admin-guide/plugins/esi.en.rst:84
msgid ""
"\"--packed-node-support\" will enable the support for using packed node, "
"which will improve the performance of parsing cached ESI document."
msgstr ""

# e860eff67da0442098d7a90059944810
#: ../../admin-guide/plugins/esi.en.rst:86
msgid ""
"\"--disable-gzip-output\" will disable gzipped output, which will NOT "
"gzip the output anyway."
msgstr ""

# a86c270039f44c7ca084731963d246b5
#: ../../admin-guide/plugins/esi.en.rst:87
msgid ""
"\"--first-byte-flush\" will enable the first byte flush feature, which "
"will flush content to users as soon as the entire ESI document is "
"received and parsed without all ESI includes fetched (the flushing will "
"stop at the ESI include markup till that include is fetched)."
msgstr ""

# 4c7751be08364bc18e09477420cc2dca
#: ../../admin-guide/plugins/esi.en.rst:91
msgid ""
"We need a mapping for origin server response that contains the ESI "
"markup. Assume that the ATS server is abc.com. And your origin server is "
"xyz.com and the response containing ESI markup is http://xyz.com/esi.php."
" We will need the following line in "
"/usr/local/etc/trafficserver/remap.config"
msgstr ""

# 8d974bc17583478db1dc295501d7b56a
#: ../../admin-guide/plugins/esi.en.rst:98
msgid ""
"Your response should contain ESI markup and a response header of 'X-Esi: "
"1'. e.g. using PHP,"
msgstr ""

