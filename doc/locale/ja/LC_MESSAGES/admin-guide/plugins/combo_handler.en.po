# a7bf6bba93074f7cb380e0a49d8f3660
#: ../../admin-guide/plugins/combo_handler.en.rst:24
msgid ""
"This plugin provides an intelligent way to combine multiple URLs into a "
"single URL, and have Apache Traffic Server combine the components into "
"one response. This is useful for example to create URLs that combine "
"multiple CSS or Javascript files into one."
msgstr ""

