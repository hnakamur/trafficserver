# 5489e73e07b04ad391776e539e19b2cb
#: ../../admin-guide/plugins/mp4.en.rst:40
msgid "Note"
msgstr ""

# d91bac6ae9f147d0bc7c155f6a180cc5
#: ../../admin-guide/plugins/mp4.en.rst:42
msgid ""
"This plugin requires that the ``moov`` box in the mp4 file should be "
"ahead of ``mdat`` box. It is not a good idea to cache a large mp4 file, "
"many video sites will cut a large video file into many small mp4 files, "
"and each small mp4 file will be less than 80M(bytes), it will be a "
"reasonable choice."
msgstr ""

