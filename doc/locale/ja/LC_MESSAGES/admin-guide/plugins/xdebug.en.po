# 32ae2d39613846c58e98b6f88cd41f76
#: ../../admin-guide/plugins/xdebug.en.rst:4
msgid "XDebug Plugin"
msgstr ""

# 8dd76d0714e64b68b6310e3e631c6176
#: ../../admin-guide/plugins/xdebug.en.rst:23
msgid ""
"The `XDebug` plugin allows HTTP clients to debug the operation of the "
"Traffic Server cache using the default ``X-Debug`` header. The plugin is "
"triggered by the presence of the ``X-Debug`` or the configured header in "
"the client request. The contents of this header should be the names of "
"the debug headers that are desired in the response. The `XDebug` plugin "
"will remove the ``X-Debug`` header from the client request and inject the"
" desired headers into the client response."
msgstr ""

# 0b9cfb79d9074bacbe2a79068f101cbe
#: ../../admin-guide/plugins/xdebug.en.rst:31
msgid ""
"`XDebug` is a global plugin. It is installed by adding it to the "
":file:`plugin.config` file. It currently takes a single, optional "
"configuration option, ``--header``. E.g."
msgstr ""

# f408137aae9f4228b029624c1d9ee38d
#: ../../admin-guide/plugins/xdebug.en.rst:35
msgid "--header=ATS-My-Debug"
msgstr ""

# d6e4b3492c19446a8b8dc94977d18205
#: ../../admin-guide/plugins/xdebug.en.rst:37
msgid "This overrides the default ``X-Debug`` header name."
msgstr ""

# 12e1e81f65234667af0fa12a02c1c073
#: ../../admin-guide/plugins/xdebug.en.rst:41
msgid "Debugging Headers"
msgstr ""

# 19b186cdb69542f286046f37f7e6a721
#: ../../admin-guide/plugins/xdebug.en.rst:43
msgid "The `XDebug` plugin is able to generate the following debugging headers:"
msgstr ""

# d59f1cda8c27430d86357aca1d4129b4
#: ../../admin-guide/plugins/xdebug.en.rst:48
msgid "Via"
msgstr ""

# 13876b06c6a740c2a07a0db285186839
#: ../../admin-guide/plugins/xdebug.en.rst:46
msgid ""
"If the ``Via`` header is requested, the `XDebug` plugin sets the "
":ts:cv:`proxy.config.http.insert_response_via_str` configuration variable"
" to ``3`` for the request."
msgstr ""

# c88ff1ea10904d7b86c98cfa02064532
#: ../../admin-guide/plugins/xdebug.en.rst:53
msgid "Diags"
msgstr ""

# ecb2c64e3d614c71898b5f3b7f822c87
#: ../../admin-guide/plugins/xdebug.en.rst:51
msgid ""
"If the ``Diags`` header is requested, the `XDebug` plugin enables the "
"transaction specific diagnostics for the transaction. This also requires "
"that :ts:cv:`proxy.config.diags.debug.enabled` is set to ``1``."
msgstr ""

# 28dbcf13f051452e9c0522846239ce9d
#: ../../admin-guide/plugins/xdebug.en.rst:58
msgid "X-Cache-Key"
msgstr ""

# 362ddd4f3d4e48de89764112109f5ebe
#: ../../admin-guide/plugins/xdebug.en.rst:56
msgid ""
"The ``X-Cache-Key`` header contains the URL that identifies the HTTP "
"object in the Traffic Server cache. This header is particularly useful if"
" a custom cache key is being used."
msgstr ""

# 12c45b5f453b434ba10af3cea65aaf8e
#: ../../admin-guide/plugins/xdebug.en.rst:71
msgid "X-Cache"
msgstr ""

# 0d692e0d8e9846828bd9a73cdb90f57a
#: ../../admin-guide/plugins/xdebug.en.rst:61
msgid "The ``X-Cache`` header contains the results of any cache lookup."
msgstr ""

