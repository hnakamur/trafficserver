msgid ""
"All parameters are optional, and if not used, their default values are as"
" mentioned below. Boolean values default to ``false`` and the rest "
"default to an empty list. Examples of each parameter's usage can be found"
" below."
msgstr ""

# 0c9b425c43334187b4827249026f76d8
# 80af0cda1e96401b87838349969aa54f
#: ../../admin-guide/plugins/cachekey.en.rst:47
#: ../../admin-guide/plugins/cachekey.en.rst:172
msgid "URI query parameters"
msgstr ""

# 538364df0bbd4ea2b3b2db91f278b552
#: ../../admin-guide/plugins/cachekey.en.rst:42
msgid ""
"If no query related plugin parameters are used, the query is included as "
"received from the UA in the cache key."
msgstr ""

# f5d610d38cf0449281ea4e084c1667ff
#: ../../admin-guide/plugins/cachekey.en.rst:43
msgid ""
"``--exclude-params`` (default: empty list) - comma-separated list of "
"query params to be black-listed in the cache key. If the list is empty "
"then no black-list is applied (no query parameters will be excluded from "
"the cache key). The exclude list overrides the include list."
msgstr ""

# a8f1fef87d234ecba45a491b6996738e
#: ../../admin-guide/plugins/cachekey.en.rst:44
msgid ""
"``--include-params`` (default: empty list) - comma-separated list of "
"query params to be white-listed in the cache key. If the list is empty "
"then no white-list is applied (all query parameters will be included in "
"the cache key)."
msgstr ""

# a67299996bf84caaaecedc069cefa4a2
#: ../../admin-guide/plugins/cachekey.en.rst:45
msgid ""
"``--include-match-params`` (default: empty list) - regular expression "
"matching query parameter names which will be white-listed in the cache "
"key."
msgstr ""

# b12e2e563a7042d2a9143c2664fa5bde
#: ../../admin-guide/plugins/cachekey.en.rst:46
msgid ""
"``--exclude-match-params`` (default: empty list) - regular expression "
"matching query parameter names which will be black-listed in the cache "
"key."
msgstr ""

# fcaefdb2d57541aea918673e42b9e4a5
#: ../../admin-guide/plugins/cachekey.en.rst:47
msgid ""
"``--remove-all-params`` (boolean:``true|false``, ``0|1``, ``yes|no``, "
"default: ``false``) - if equals ``true`` then all query parameters are "
"removed (the whole query string) and all other URI query parameter "
"related settings (if used) will have no effect."
msgstr ""

# 70c4314fabfa49868a1297d3334f5b42
#: ../../admin-guide/plugins/cachekey.en.rst:48
msgid ""
"``--sort-params`` (boolean:``true|false``, ``0|1``, ``yes|no``, default: "
"``false``) - if equals ``true`` then all query parameters are sorted in "
"an increasing case-sensitive order"
msgstr ""

# 70997d569cdc41949caf5d52b152e367
#: ../../admin-guide/plugins/cachekey.en.rst:49
msgid "HTTP headers"
msgstr ""

# 1b60f0778adc470086eca9692ed71df4
#: ../../admin-guide/plugins/cachekey.en.rst:50
msgid ""
"``--include-headers`` (default: empty list) - comma separated list of "
"headers to be added to the cache key."
msgstr ""

# cea9623ab5644ff083b5f42d3b9ffe60
#: ../../admin-guide/plugins/cachekey.en.rst:52
msgid "HTTP cookies"
msgstr ""

# 1f7db92647c3427b8bc41a04c29f535d
#: ../../admin-guide/plugins/cachekey.en.rst:52
msgid ""
"``--include-cookies`` (default: empty list) - comma separated list of "
"cookies to be added to the cache key."
msgstr ""

# b988eefe780b4001a7025d311f05dda7
#: ../../admin-guide/plugins/cachekey.en.rst:58
msgid "Host name, port and custom prefix"
msgstr ""

# c9cf8ff1adbc48df9ac2ed279257f1f5
#: ../../admin-guide/plugins/cachekey.en.rst:55
msgid ""
"Host and port are added to the beginning of the cache key by default "
"unless a custom preffix by using ``--static-prefix`` or ``--capture-"
"prefix`` plugin parameters is specified."
msgstr ""

# 5c9beb3aed944400ab5bc9c209fcb29e
#: ../../admin-guide/plugins/cachekey.en.rst:56
msgid ""
"``--static-prefix`` (default: empty string) - if specified and not an "
"empty string the value will be added to the beginning of the cache key."
msgstr ""

# 3cf25d7b221e47b5be76b3a91ba0fb70
#: ../../admin-guide/plugins/cachekey.en.rst:57
msgid ""
"``--capture-prefix=<capture_definition>`` (default: empty string) - if "
"specified and not an empty string will capture strings from ``host:port``"
" based on the ``<capture_definition>`` (see below) and add them to the "
"beginning of the cache key."
msgstr ""

# 586bfba857e9447cbf6899f233ec90d8
#: ../../admin-guide/plugins/cachekey.en.rst:58
msgid ""
"If ``--static-prefix`` and ``--capture-prefix`` are used together then "
"the value of ``--static-prefix`` is added first to the cache key, "
"followed by the ``--capture-prefix`` capturing/replacement results."
msgstr ""

# 98f9704f122a435dadbc129b450b14b1
#: ../../admin-guide/plugins/cachekey.en.rst:62
msgid "``User-Agent`` classification"
msgstr ""

# 7e1a3df1f5c9422886642420d28b8696
#: ../../admin-guide/plugins/cachekey.en.rst:61
msgid ""
"``--ua-whitelist=<classname>:<filename>`` (default: empty string) - loads"
" a regex patterns list from a file ``<filename>``, the patterns are "
"matched against the ``User-Agent`` header and if matched ``<classname>`` "
"is added it to the key."
msgstr ""

# 33f041574ad84be2b20e6831034851cc
#: ../../admin-guide/plugins/cachekey.en.rst:62
msgid ""
"``--ua-blacklist=<classname>:<filename>`` (default: empty string) - loads"
" a regex patterns list from a file ``<filename>``, the patterns are "
"matched against the ``User-Agent`` header and if **not** matched "
"``<classname>`` is added it to the key."
msgstr ""

# c64d7c1b18e74dbb8f879bea6c737387
#: ../../admin-guide/plugins/cachekey.en.rst:65
msgid "``User-Agent`` regex capturing and replacement"
msgstr ""

# ed608472211a4902b33ada7b017fcd59
#: ../../admin-guide/plugins/cachekey.en.rst:65
msgid ""
"``--ua-capture=<capture_definition>`` (default: empty string) - if "
"specified and not an empty string will capture strings from ``User-"
"Agent`` header based on ``<capture_definition>`` (see below) and will add"
" them to the cache key."
msgstr ""

# 107609b0a59249d99b5cc4975930f2d7
#: ../../admin-guide/plugins/cachekey.en.rst:69
msgid "``<capture_definition>`` can be in the following formats"
msgstr ""

# 124a57e12e7343b292ca45a6277f09d1
#: ../../admin-guide/plugins/cachekey.en.rst:68
msgid ""
"``<regex>`` - ``<regex>`` defines regex capturing groups, up to 10 "
"captured strings based on ``<regex>`` will be added to the cache key."
msgstr ""

# 96f97b0e27d84ccdbe8b6d0dc6f51fa0
#: ../../admin-guide/plugins/cachekey.en.rst:69
msgid ""
"``/<regex>/<replacement>/`` - ``<regex>`` defines regex capturing groups,"
" ``<replacement>`` defines a pattern where the captured strings "
"referenced with ``$0`` ... ``$9`` will be substituted and the result will"
" be added to the cache key."
msgstr ""

