# eb8bf2ced85148029e2082186f0e2fd4
#: ../../admin-guide/plugins/cacheurl.en.rst:4
msgid "CacheURL Plugin"
msgstr ""

# d643aa83144b41c7a25dab7e917f3848
#: ../../admin-guide/plugins/cacheurl.en.rst:25
msgid ""
"This plugin allows you to change the key that is used for caching a "
"request by using any portion of the url via regex. It is designed so that"
" multiple requests that have different URLs but the same content (for "
"example, site mirrors) need be cached only once."
msgstr ""

# 5535320ffe9a42efa836e3f82d05991c
#: ../../admin-guide/plugins/cacheurl.en.rst:31
msgid "Installation"
msgstr ""

# 944be1be8f9d45d39090bc46c499069c
#: ../../admin-guide/plugins/cacheurl.en.rst:33
msgid "This plugin is only built if the configure option ::"
msgstr ""

# 3c53c712469344bdaf4ad264965b4909
#: ../../admin-guide/plugins/cacheurl.en.rst:37
msgid "is given at build time."
msgstr ""

# ffeb891b0c2a4b698384ab60c3830fd8
#: ../../admin-guide/plugins/cacheurl.en.rst:40
msgid "Configuration"
msgstr ""

# 759f1afa54b146df8d26d1e176cc185f
#: ../../admin-guide/plugins/cacheurl.en.rst:42
msgid ""
"Create a ``cacheurl.config`` file in the plugin directory with the url "
"regex patterns to match."
msgstr ""

# 92e16020e3324656bfb1bf6526c7de04
#: ../../admin-guide/plugins/cacheurl.en.rst:45
msgid "``url_pattern   cache_key_replacement``"
msgstr ""

# a53317ddf29e42ffa94edfe6b0acc106
#: ../../admin-guide/plugins/cacheurl.en.rst:48
msgid ""
"The url_pattern is a regular expression (pcre). The replacement can "
"contain $1, $2 and so on, which will be replaced with the appropriate "
"matching group from the pattern."
msgstr ""

# a211c7727160475da21f6c8bd1dc424c
#: ../../admin-guide/plugins/cacheurl.en.rst:50
msgid "Add the plugin to your :file:`plugin.config` file::"
msgstr ""

# 8956550075a646b1bd8fc02e9faa3e8c
#: ../../admin-guide/plugins/cacheurl.en.rst:54
msgid ""
"Start traffic server. Any rewritten URLs will be written to "
"``cacheurl.log`` in the log directory by default."
msgstr ""

# 1101f7ac7aeb4ddea85361378432da3d
#: ../../admin-guide/plugins/cacheurl.en.rst:58
msgid "Examples"
msgstr ""

# 5db15128acc840eb8e795ee2e3fc2a58
#: ../../admin-guide/plugins/cacheurl.en.rst:59
msgid ""
"To make files from s1.example.com, s2.example.com and s3.example.com all "
"be cached with the same key. Adding a unique suffix (TSINTERNAL in this "
"example) to the cache key guarantees that it won't clash with a real URL "
"should s.example.com exist."
msgstr ""

# 8e130253238e429a9f145a71eb5ec780
#: ../../admin-guide/plugins/cacheurl.en.rst:61
msgid "``http://s[123].example.com/(.*)  http://s.example.com.TSINTERNAL/$1``"
msgstr ""

# a36ced20a88844ca90e5159157f8e51f
#: ../../admin-guide/plugins/cacheurl.en.rst:63
msgid ""
"Cache based on only some parts of a query string (e.g. ignore session "
"information). This plucks out the id and format query string variables "
"and only considers those when making the cache key."
msgstr ""

# 55f3d9ed5c3d4f8d872b573445090eb0
#: ../../admin-guide/plugins/cacheurl.en.rst:65
msgid ""
"``http://www.example.com/video\\?.*?\\&?(id=[0-9a-f]*).*?\\&(format=[a-z]*)"
" http://video-srv.example.com.ATSINTERNAL/$1&$2``"
msgstr ""

# 94609171561b408d95040867496d2f4c
#: ../../admin-guide/plugins/cacheurl.en.rst:67
msgid "Completely ignore a query string for a specific page"
msgstr ""

# bfafad0e370b4ca3adaf831ff0da407f
#: ../../admin-guide/plugins/cacheurl.en.rst:69
msgid ""
"``http://www.example.com/some/page.html(?:\\?|$) "
"http://www.example.com/some/page.html``"
msgstr ""

