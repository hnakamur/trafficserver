# f8be54862c8840b4a041d610f32f64cb
#: ../../admin-guide/storage/index.en.rst:222
msgid ""
"When you increase the size of a volume, the contents of the volume are "
"*not* deleted. However, when you reduce the size of a volume, the "
"contents of the volume *are* deleted."
msgstr ""

# fdb5e569a5824f0f9160666dbcbb55d0
#: ../../admin-guide/storage/index.en.rst:226
msgid ""
