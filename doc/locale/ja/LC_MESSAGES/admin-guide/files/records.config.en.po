# 110b57578c824f85a60e360fd91772db
#: ../../admin-guide/files/records.config.en.rst:2400
msgid ""
"authenticated during the SSL handshake. Clients without a certificate are"
" not allowed to access Traffic Server."
msgstr ""

# 2662c62c8d64439c81108b862ae711f4
#: ../../admin-guide/files/records.config.en.rst:2405
msgid "Sets the number of SSL threads to use, this defaults to 0 (autoconfigure)."
msgstr ""

# dc2c316be0be484492c434238cfb7b7c
#: ../../admin-guide/files/records.config.en.rst:2407
msgid ""
"``0`` = autoconfigure, this will allow Traffic Server to determine the "
"appropriate number of threads"
msgstr ""

# 52eae119849447bba7ef6d29f4c3a7ac
