msgid ""
"This is an ordered list of keywords separated by semicolons that specify "
"how a host name is to be resolved to an IP address. The keywords are case"
" insensitive."
msgstr ""

# 23e63f755ef34e6d930bc866aecf3b45
#: ../../admin-guide/files/records.config.en.rst:1988
msgid "Keyword"
msgstr ""

# fd5d7faab88140948bba01cd9b378ffc
#: ../../admin-guide/files/records.config.en.rst:1988
msgid "Meaning"
msgstr ""

# 29697a92ed114456850f307493f230fa
#: ../../admin-guide/files/records.config.en.rst:1990
msgid "Resolve to an IPv4 address."
msgstr ""

# e7175d78b5a145c8b355e2fc4247c040
#: ../../admin-guide/files/records.config.en.rst:1991
msgid "Resolve to an IPv6 address."
msgstr ""

# 4d85c81350c74ec39f03de6a30f34e9c
#: ../../admin-guide/files/records.config.en.rst:1992
msgid "client"
msgstr ""

# faa1e5f1768a45a2af7886d524227ccc
#: ../../admin-guide/files/records.config.en.rst:1992
msgid "Resolve to the same family as the client IP address."
msgstr ""

# b1cc9e49e0764271a08678a7b02c8018
#: ../../admin-guide/files/records.config.en.rst:1993
msgid "Stop resolving."
msgstr ""

