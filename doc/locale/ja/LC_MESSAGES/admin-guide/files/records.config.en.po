# 953656728a6d4a16b1b9253deed79a9c
#: ../../admin-guide/files/records.config.en.rst:2535
msgid ""
"``1`` = Don't use the SSL session cache for this connection during lock "
"contention."
msgstr ""

# 6d7c76494cdc4cf2a0de4dffbd55959f
#: ../../admin-guide/files/records.config.en.rst:2539
msgid ""
