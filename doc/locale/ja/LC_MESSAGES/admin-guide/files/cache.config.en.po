msgstr ""

# d532fa34d5e24d69a94e5570ba29a62d
#: ../../admin-guide/files/cache.config.en.rst:119
msgid "``internal``"
msgstr ""

# 330840cace6340ea8a8aabca3c7ae131
#: ../../admin-guide/files/cache.config.en.rst:117
msgid ""
"A boolean value, ``true`` or ``false``, specifying if the rule should "
"match (or not match) a transaction originating from an internal API. This"
" is useful to differentiate transaction originating from an ATS plugin."
msgstr ""

# 8ac0f3f5eed84ab1942686c516ff9c78
#: ../../admin-guide/files/cache.config.en.rst:121
msgid "The following list shows possible actions and their allowed values."
msgstr ""

# 651bc00b03124ea3bbae325dc1be9262
#: ../../admin-guide/files/cache.config.en.rst:138
msgid "``action``"
msgstr ""

# db51afe23fb5489f8153f1b4834bca9a
#: ../../admin-guide/files/cache.config.en.rst:127
msgid "One of the following values:"
msgstr ""

# 37236b1805c34583bcb7a8cdad0652cf
#: ../../admin-guide/files/cache.config.en.rst:129
msgid ""
"``never-cache`` configures Traffic Server to never cache specified "
"objects."
msgstr ""

# 87f67950d50c40998e5f81720d67b0e8
#: ../../admin-guide/files/cache.config.en.rst:131
msgid ""
"``ignore-no-cache`` configures Traffic Server to ignore all ``Cache-"
"Control: no-cache`` headers."
msgstr ""

# 409019dbdf334e40b9296b6f6da62d71
#: ../../admin-guide/files/cache.config.en.rst:133
msgid ""
"``ignore-client-no-cache`` configures Traffic Server to ignore ``Cache-"
"Control: no-cache`` headers from client requests."
msgstr ""

# 217dd06915824d488469f7a5d9c0fdc6
#: ../../admin-guide/files/cache.config.en.rst:135
msgid ""
"``ignore-server-no-cache`` configures Traffic Server to ignore ``Cache-"
"Control: no-cache`` headers from origin server responses."
msgstr ""

# a8aabe2c9a2c41d79456f421d1b3fa87
#: ../../admin-guide/files/cache.config.en.rst:137
msgid ""
"``cluster-cache-local`` configures the cluster cache to allow for this "
"content to be stored locally on every cluster node."
msgstr ""

# 4c369559a4544347b0729c00624400df
#: ../../admin-guide/files/cache.config.en.rst:148
msgid "``cache-responses-to-cookies``"
msgstr ""

# abe14f90e97f4e02910365e58c3bb8b3
#: ../../admin-guide/files/cache.config.en.rst:143
msgid ""
"Change the style of caching with regard to cookies. This effectively "
"overrides the configuration parameter "
":ts:cv:`proxy.config.http.cache.cache_responses_to_cookies` and uses the "
"same values with the same semantics. The override happens only for "
"requests that match."
msgstr ""

# 4add5114eff24cc19c74a86700cbf29f
#: ../../admin-guide/files/cache.config.en.rst:168
msgid "``pin-in-cache``"
msgstr ""

# cb95fe95269e45aebab4086aefc21633
#: ../../admin-guide/files/cache.config.en.rst:153
msgid ""
"Preserves objects in cache, preventing them from being overwritten. Does "
"not affect objects that are determined not to be cacheable. This setting "
"can have performance issues, and  severely affect the cache. For "
"instance, if the primary destination matches all objects, once the cache "
"is full, no new objects could get written as nothing would be evicted.  "
"Similarly, for each cache-miss, each object would incur extra checks to "
"determine if the object it would replace could be overwritten."
msgstr ""

# 68548e72f2ef4a70939efdf054157fba
#: ../../admin-guide/files/cache.config.en.rst:161
msgid ""
"The value is the amount of time you want to keep the object(s) in the "
"cache. The following time formats are allowed:"
msgstr ""

# ea5339e8b998478f8b13d48d49f6c416
#: ../../admin-guide/files/cache.config.en.rst:164
msgid "``d`` for days; for example: 2d"
msgstr ""

# f97636e806794392ba92ff8ab6b73a66
#: ../../admin-guide/files/cache.config.en.rst:165
msgid "``h`` for hours; for example: 10h"
msgstr ""

# a8c7db01538046efb9af8762eb4ca27f
#: ../../admin-guide/files/cache.config.en.rst:166
msgid "``m`` for minutes; for example: 5m"
msgstr ""

# b7d05433c8904d078615ded37859968e
#: ../../admin-guide/files/cache.config.en.rst:167
msgid "``s`` for seconds; for example: 20s"
msgstr ""

# c3213050181b47f2ae612f58c21dd8c9
#: ../../admin-guide/files/cache.config.en.rst:168
msgid "mixed units; for example: 1h15m20s"
msgstr ""

# 3881257379204b53bf6090180cdedc50
#: ../../admin-guide/files/cache.config.en.rst:174
msgid "``revalidate``"
msgstr ""

# e8d41e67e9534b579146f30a002c74ec
#: ../../admin-guide/files/cache.config.en.rst:173
msgid ""
"For objects that are in cache, overrides the the amount of time the "
"object(s) are to be considered fresh. Use the same time formats as ``pin-"
"in-cache``."
msgstr ""

# e3c45da08ef84d14a7b62ba3fc3773a9
#: ../../admin-guide/files/cache.config.en.rst:182
msgid "``ttl-in-cache``"
msgstr ""

# c9b127717e694ea3955ff3e28d5d7500
#: ../../admin-guide/files/cache.config.en.rst:179
msgid ""
"Forces object(s) to become cached, as if they had a Cache-Control: max-"
"age:<time> header. Can be overruled by requests with cookies. The value "
"is the amount of time object(s) are to be kept in the cache, regardless "
"of Cache-Control response headers. Use the same time formats as pin-in-"
"cache and revalidate."
msgstr ""

# c5617e16a4324184a3a3f3fdf431bb31
#: ../../admin-guide/files/cache.config.en.rst:185
msgid "Examples"
msgstr ""

