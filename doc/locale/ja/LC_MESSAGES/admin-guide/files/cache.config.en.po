msgstr ""

# ac383a12c9044c7a9d3dda562d111d1c
#: ../../admin-guide/files/cache.config.en.rst:92
msgid "``prefix``"
msgstr ""

# 20a9c152b39c48b5a7240cfa78352bfa
#: ../../admin-guide/files/cache.config.en.rst:92
msgid "A prefix in the path part of a URL."
msgstr ""

# 57e10413952d4b9482dcab245c69368b
#: ../../admin-guide/files/cache.config.en.rst:97
msgid "``suffix``"
msgstr ""

# f516baf9d5a042829775f6bd23b6d18b
#: ../../admin-guide/files/cache.config.en.rst:97
msgid "A file suffix in the URL."
msgstr ""

# c7f3c8a65929415c856e50800ec2c75a
#: ../../admin-guide/files/cache.config.en.rst:102
msgid "``method``"
msgstr ""

# aad2575c28b14685bc9f86b203083761
#: ../../admin-guide/files/cache.config.en.rst:102
msgid "A request URL method: get, put, post, trace."
msgstr ""

# e5a6619c4b1d4a33855abd6d13ebeb78
#: ../../admin-guide/files/cache.config.en.rst:107
msgid "``time``"
msgstr ""

# 6c4fe1ab39644e60b0fc49b6524569f1
#: ../../admin-guide/files/cache.config.en.rst:107
msgid "A time range, such as 08:00-14:00."
