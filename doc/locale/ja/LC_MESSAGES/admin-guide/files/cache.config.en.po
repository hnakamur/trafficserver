# 478b1c7a2a3848b98f6e667f82dbb334
#: ../../admin-guide/files/cache.config.en.rst:112
msgid "``src_ip``"
msgstr ""

# df182ffecda44bcab9b075209f7d53f2
#: ../../admin-guide/files/cache.config.en.rst:112
