# f8494de3c74a4b26b1cf40a6d8af0349
#: ../../admin-guide/files/splitdns.config.en.rst:20
msgid "splitdns.config"
msgstr ""

# f76aa998e9034f2ea413f2e983bb61eb
#: ../../admin-guide/files/splitdns.config.en.rst:24
msgid ""
"The :file:`splitdns.config` file enables you to specify the DNS server "
"that Traffic Server should use for resolving hosts under specific "
"conditions. For more information, refer to :ref:`admin-split-dns`."
msgstr ""

# bbf1c9e29bf040809308cc7bc0248edd
#: ../../admin-guide/files/splitdns.config.en.rst:28
msgid ""
"To specify a DNS server, you must supply the following information in "
"each active line within the file:"
msgstr ""

# 668a2f45b41847d59640c29d438b8893
#: ../../admin-guide/files/splitdns.config.en.rst:31
msgid ""
"A primary destination specifier in the form of a destination domain, a "
"destination host, or a URL regular expression"
msgstr ""

# 371ecbe365e743faaba7b1067009e92e
#: ../../admin-guide/files/splitdns.config.en.rst:33
msgid ""
"A set of server directives, listing one or more DNS servers with "
"corresponding port numbers"
msgstr ""

# af7c5619b5704db9b133a49467f6c6f6
#: ../../admin-guide/files/splitdns.config.en.rst:36
msgid ""
"You can also include the following optional information with each DNS "
"server specification:"
msgstr ""

# d6735624fa1c46588ff4dcceae459828
#: ../../admin-guide/files/splitdns.config.en.rst:39
msgid "A default domain for resolving hosts"
msgstr ""

# 475358a36c6645d9ba6759f19d1835ce
#: ../../admin-guide/files/splitdns.config.en.rst:40
msgid ""
"A search list specifying the domain search order when multiple domains "
"are specified"
msgstr ""

# 98a778c6687a4490885f8675b2b1c628
#: ../../admin-guide/files/splitdns.config.en.rst:43
msgid ""
"After you modify the :file:`splitdns.config` file, run the "
":option:`traffic_ctl config reload` command to apply the changes. When "
"you apply changes to a node in a cluster, Traffic Server automatically "
"applies the changes to all other nodes in the cluster."
msgstr ""

# 4609fa0edfdf46828c96bb21690b635f
#: ../../admin-guide/files/splitdns.config.en.rst:50
msgid "Format"
msgstr ""

# 63cfcadcbcb241b78055896411dee1ce
#: ../../admin-guide/files/splitdns.config.en.rst:52
msgid ""
"Each line in the :file:`splitdns.config` file uses one of the following "
"formats: ::"
msgstr ""

# 6153559becf346149ae5dbdbf68f46be
#: ../../admin-guide/files/splitdns.config.en.rst:57
msgid "The following list describes each field."
msgstr ""

# 01a561b73b4b4e0190d57dbec6a62ba9
#: ../../admin-guide/files/splitdns.config.en.rst:64
msgid "``dest_domain``"
msgstr ""

# c22d48e47159494ea71e5e12c3fd8a3a
#: ../../admin-guide/files/splitdns.config.en.rst:62
msgid ""
"A valid domain name. This specifies that DNS server selection will be "
"based on the destination domain. You can prefix the domain with an "
"exclamation mark (``!``) to indicate the NOT logical operator."
msgstr ""

# 882855f6a31f4ebbb6fefacda4b8980a
#: ../../admin-guide/files/splitdns.config.en.rst:71
msgid "``dest_host``"
msgstr ""

# 72e1275a1f584237a67b107023373714
#: ../../admin-guide/files/splitdns.config.en.rst:69
msgid ""
"A valid hostname. This specifies that DNS server selection will be based "
"on the destination host. You can prefix the host with an exclamation mark"
" (``!``) to indicate the ``NOT`` logical operator."
msgstr ""

# 9fa54e7f0e244a09a11bd8b5598cb266
#: ../../admin-guide/files/splitdns.config.en.rst:77
msgid "``url_regex``"
msgstr ""

# 44eeb11cb9c848f5800a6ffe0bd33813
#: ../../admin-guide/files/splitdns.config.en.rst:76
msgid ""
"A valid URL regular expression. This specifies that DNS server selection "
"will be based on a regular expression."
msgstr ""

# 80d0c50696d046aba94fb077b2df597f
#: ../../admin-guide/files/splitdns.config.en.rst:89
msgid "``named``"
msgstr ""

# 1fcf9ea4b2e1404983b0c0950f921e8d
#: ../../admin-guide/files/splitdns.config.en.rst:82
msgid ""
"This is a required directive. It identifies the DNS server that Traffic "
"Server should use with the given destination specifier. You can specify a"
" port using a colon (``:``). If you do not specify a port, then 53 is "
"used. Specify multiple DNS servers with spaces or semicolons (``;``) as "
"separators."
msgstr ""

# 87d3d297a3bd45d9b56d61e246296bfa
#: ../../admin-guide/files/splitdns.config.en.rst:88
msgid "You must specify the domains with IP addresses in CIDR (\"dot\") notation."
msgstr ""

# 549f486280b1480883b8d4ff7043acd0
#: ../../admin-guide/files/splitdns.config.en.rst:97
msgid "``def_domain``"
msgstr ""

# 9219839de5fa465fbd4faf3600612303
#: ../../admin-guide/files/splitdns.config.en.rst:94
msgid ""
"A valid domain name. This optional directive specifies the default domain"
" name to use for resolving hosts. Only one entry is allowed. If you do "
"not provide the default domain, the system determines its value from "
"``/etc/resolv.conf``"
msgstr ""

# 3db71124bb934990b87abba407067c8e
#: ../../admin-guide/files/splitdns.config.en.rst:104
msgid "``search_list``"
msgstr ""

# 8fa9c429bb314833b7fb78268ed1552b
#: ../../admin-guide/files/splitdns.config.en.rst:102
msgid ""
"A list of domains separated by spaces or semicolons (;). This specifies "
"the domain search order. If you do not provide the search list, the "
"system determines the value from :manpage:`resolv.conf(5)`"
msgstr ""

# bfb477f2251845b9b5af45c550c6f932
#: ../../admin-guide/files/splitdns.config.en.rst:107
msgid "Examples"
msgstr ""

# 6fff89a6922049aa93355f0f5d456cbc
#: ../../admin-guide/files/splitdns.config.en.rst:109
msgid "Consider the following DNS server selection specifications: ::"
msgstr ""

# d273b016f6f2428cbfbd684ec92da1b6
#: ../../admin-guide/files/splitdns.config.en.rst:114
msgid "Now consider the following two requests: ::"
msgstr ""

# e5850ddcd41b42a883fc3dfcb80a2026
#: ../../admin-guide/files/splitdns.config.en.rst:118
msgid ""
"This request matches the first line and therefore selects DNS server "
"``255.255.255.255`` on port ``212``. All resolver requests use "
"``company.com`` as the default domain, and ``company.com`` and "
"``company1.com`` as the set of domains to search first. ::"
msgstr ""

# eb51ae132d4f4778b2b23c1c37af9265
#: ../../admin-guide/files/splitdns.config.en.rst:125
msgid ""
"This request matches the second line. Therefore, Traffic Server selects "
"DNS server ``255.255.255.253``. Because no ``def_domain`` or "
"``search_list`` was supplied, Traffic Server retrieves this information "
"from :manpage:`resolv.conf(5)`"
msgstr ""

