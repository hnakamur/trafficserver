msgstr ""

# 1ba5b73d0c994055bee8c25eccbec9a8
#: ../../developer-guide/plugins/example-plugins/query-remap/index.en.rst:55
msgid "A remap plugin is required to implement the following functions:"
msgstr ""

# ee546f2711504a8db83c09a1613ac525
#: ../../developer-guide/plugins/example-plugins/query-remap/index.en.rst:57
msgid ""
"`TSRemapInit "
"<http://people.apache.org/~amc/ats/doc/html/remap_8h.html#af7e9b1eee1c38c6f8dcc67a65ba02c24>`_:"
" the remap initialization function, called once when the plugin is loaded"
msgstr ""

# 903c507951d44c91a0dcc427de9924e3
#: ../../developer-guide/plugins/example-plugins/query-remap/index.en.rst:61
msgid ""
"`TSRemapNewInstance "
"<http://people.apache.org/~amc/ats/doc/html/remap_8h.html#a963de3eeed2ed7a2da483acf77dc42ca>`_:"
" a new instance is created for each rule associated with the plugin. "
"Called each time the plugin used in a remap rule (this function is what "
"processes the pparam values)"
msgstr ""

# 70cd869ab2b5409bba06f734ec7bbad1
#: ../../developer-guide/plugins/example-plugins/query-remap/index.en.rst:66
msgid ""
"`TSRemapDoRemap "
"<http://people.apache.org/~amc/ats/doc/html/remap_8h.html#acf73f0355c591e145398211b3c0596fe>`_:"
" the entry point used by Traffic Server to find the new URL to which it "
"remaps; called every time a request comes in"
msgstr ""

