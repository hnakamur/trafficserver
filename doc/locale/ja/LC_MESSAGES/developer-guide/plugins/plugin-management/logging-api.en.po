msgid "Logging API"
msgstr ""

# 3051b9c670844a93af84f2d9f7bb4580
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:25
msgid ""
"The logging API enables your plugin to log entries in a custom text log "
"file that you create with the call :c:func:`TSTextLogObjectCreate`. This "
"log file is part of Traffic Server's logging system; by default, it is "
"stored in the logging directory. Once you have created the log object, "
"you can set log properties."
msgstr ""

# 6c5af20c8f7c4a049eedfedbe99002cb
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:31
msgid "The logging API enables you to:"
msgstr ""

# 4f1135f271c249b1816980a956d0df93
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:33
msgid ""
"Establish a custom text log for your plugin: see "
":c:func:`TSTextLogObjectCreate`"
msgstr ""

# e857c2111e2349799c5fb18584479e00
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:36
msgid ""
"Set the log header for your custom text log: see "
":c:func:`TSTextLogObjectHeaderSet`"
msgstr ""

# 553918ff33c04211aa0444785ca8178f
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:39
msgid ""
"Enable or disable rolling your custom text log: see "
":c:func:`TSTextLogObjectRollingEnabledSet`"
msgstr ""

# 90c7fbe68c884df9b102946d4fe1d062
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:42
msgid ""
"Set the rolling interval (in seconds) for your custom text log: see "
":c:func:`TSTextLogObjectRollingIntervalSecSet`"
msgstr ""

# 31e6f9d01e36448f938b1b4eea626145
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:45
msgid ""
"Set the rolling offset for your custom text log: see "
":c:func:`TSTextLogObjectRollingOffsetHrSet`"
msgstr ""

# c3b08aff53234954960ea485b7690094
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:48
msgid ""
"Set the rolling size for your custom text log: see "
":c:func:`TSTextLogObjectRollingSizeMbSet`"
msgstr ""

# 2d1b65a4c1e7485f8eac42521be16758
#: ../../developer-guide/plugins/plugin-management/logging-api.en.rst:51
msgid ""
"Write text entries to the custom text log: see "
