#: ../../developer-guide/api/functions/TSHttpTxnInfoIntGet.en.rst:40
msgid ""
"This info is available at or after "
":c:data:`TS_HTTP_CACHE_LOOKUP_COMPLETE_HOOK` hook. A value of 1 indicates"
" that the response is returned from RAM cache. A value of 0 indicates "
"otherwise."
msgstr ""

