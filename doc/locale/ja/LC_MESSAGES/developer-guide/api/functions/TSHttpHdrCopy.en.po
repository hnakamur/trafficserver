# cc4643fe46f0489fb5c7bd997694323a
#: ../../developer-guide/api/functions/TSHttpHdrCopy.en.rst:24
msgid ""
"Copies the contents of the HTTP header located at src_loc within src_bufp"
" to the HTTP header located at dest_loc within dest_bufp."
msgstr ""

