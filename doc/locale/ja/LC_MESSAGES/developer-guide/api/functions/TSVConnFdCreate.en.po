# 499287629d9d4ed6a8f82cfc20a90d9a
#: ../../developer-guide/api/functions/TSVConnFdCreate.en.rst:36
msgid ""
":func:`TSVConnFdCreate` accepts a network socket :arg:`fd` and returns a "
"new :type:`TSVConn` constructed from the socket. The socket descriptor "
"must be an already connected socket. It will be placed into non-blocking "
"mode."
msgstr ""

# b13a2359c520481cb55b54f8d8acd2a0
#: ../../developer-guide/api/functions/TSVConnFdCreate.en.rst:41
msgid "Return Values"
msgstr ""

# 00e3c496bd0a478b9c8f620686c89e3a
#: ../../developer-guide/api/functions/TSVConnFdCreate.en.rst:43
msgid ""
"On success, the returned :type:`TSVConn` object owns the socket and the "
"caller must not close it. If :func:`TSVConnFdCreate` fails, "
":literal:`NULL` is returned, the socket is unchanged and the caller must "
"close it."
msgstr ""

